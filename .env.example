# Copy to .env for local testing. On Vercel, set these in
# Project Settings -> Environment Variables instead.

# From @BotFather
TOKEN=123456:your-telegram-bot-token

# Your numeric Telegram user id (the "keeper"). Get it from @userinfobot.
ADMIN_ID=000000000

# Upstash Redis connection string (starts with rediss://).
# Upstash console -> your database -> "Redis URL".
REDIS_URL=rediss://default:password@your-db.upstash.io:6379

# Any random string. Must match what you pass to set_webhook.py.
# Leave blank to disable the check.
WEBHOOK_SECRET=
