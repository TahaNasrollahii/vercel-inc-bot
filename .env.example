# Copy to .env for local testing. On Vercel, set these in
# Project Settings -> Environment Variables instead.

# From @BotFather
TOKEN=123456:your-telegram-bot-token

# Your numeric Telegram user id (the "keeper"). Get it from @userinfobot.
ADMIN_ID=000000000

# Upstash Redis connection string (starts with rediss://).
# Upstash console -> your database -> "Redis URL".
REDIS_URL=rediss://default:password@your-db.upstash.io:6379

# Any random string. Must match what you pass to set_webhook.py.
# Leave blank to disable the check.
WEBHOOK_SECRET=

# Any random string guarding the /api/cron endpoint (vow reminders).
# The external scheduler (cron-job.org) must send it as
# `Authorization: Bearer <CRON_SECRET>`. Leave blank to disable the check.
CRON_SECRET=

# Public URL of the deployed Mini App (e.g. https://your-project.vercel.app).
# Adds an "open the corridor" button to the bot's reply keyboard. Leave blank
# and that button is simply omitted (the rest of the keyboard still works).
WEBAPP_URL=

# ================== AI CONFIG ==================
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
AI_API_KEY=

# Tuning defaults
TEMPERATURE=0.7
MAX_TOKENS=1024
MAX_CONTEXT_MESSAGES=15
RATE_LIMIT_PER_MINUTE=5
RATE_LIMIT_PER_HOUR=50
CACHE_TTL=300

